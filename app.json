{
  "expo": {
    "name": "expo-music-player",
    "slug": "expo-music-player",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "expomusicplayer",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.geneslam.expomusicplayer"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.geneslam.expomusicplayer"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/LexendDeca-Regular.ttf",
            "./assets/fonts/LexendDeca-Bold.ttf",
            "./assets/fonts/LexendDeca-ExtraBold.ttf",
            "./assets/fonts/LexendDeca-ExtraLight.ttf",
            "./assets/fonts/LexendDeca-Light.ttf",
            "./assets/fonts/LexendDeca-Medium.ttf",
            "./assets/fonts/LexendDeca-SemiBold.ttf",
            "./assets/fonts/LexendDeca-Thin.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5d912603-cac6-4fba-8cf9-2601cf86c40a"
      }
    }
  }
}
